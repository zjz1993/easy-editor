    "@tiptap/pm": "^3.28.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@textory/context": "workspace:^",
    "@textory/editor-common-ui": "workspace:^",
    "@textory/editor-utils": "workspace:^",
    "classnames": "^2.5.1",
    "lodash-es": "^4.18.0",
    "rc-upload": "^4.9.0",
    "react-intl-universal": "^2.12.0"
  },
  "devDependencies": {
    "@tiptap/core": "^3.28.0",
    "@tiptap/extension-bubble-menu": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0"
  }
