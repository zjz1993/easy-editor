{
  "name": "@textory/editor-common-ui",
  "version": "0.0.1",
  "private": false,
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist && rm -rf .turbo",
    "dev": "tsup src/index.ts --format esm --watch --silent --dts",
    "build": "tsup --config tsup.config.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.4",
    "@textory/context": "workspace:^",
    "ahooks": "^3.8.4",
    "classnames": "^2.5.1",
    "framer-motion": "^12.23.12",
    "lodash-es": "^4.18.0",
    "rc-input-number": "^9.4.0",
    "rc-trigger": "^5.3.4",
    "react-intl-universal": "^2.12.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0"
  }
}
